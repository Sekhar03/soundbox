// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("OPERATIONS")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bank {
  id        String   @id @default(uuid())
  name      String   @unique
  indents   Indent[]
}

model CourierPartner {
  id        String   @id @default(uuid())
  name      String   @unique
  indents   Indent[]
}

model Merchant {
  id        String   @id @default(uuid())
  name      String
  mobile    String
  indent    Indent?
}

model Indent {
  id                  String             @id @default(uuid())
  merchantId          String             @unique
  merchant            Merchant           @relation(fields: [merchantId], references: [id])
  bankId              String
  bank                Bank               @relation(fields: [bankId], references: [id])
  deliveryType        String             // CAPEX, OPEX
  indentDate          DateTime           @default(now())
  merchantAcceptDeny  String             @default("PENDING") // ACCEPTED, DENIED, etc.
  mappingStatus       String             @default("UNMAPPED") // MAPPED, UNMAPPED
  pickupStatus        Boolean            @default(false)
  deliveryStatus      String             @default("PICKUP")
  installationStatus  String             @default("PENDING")
  activationStatus    String             @default("PENDING")
  courierPartnerId    String?
  courierPartner      CourierPartner?    @relation(fields: [courierPartnerId], references: [id])
  agentName           String?
  remarks             String?
  pendingSince        DateTime           @default(now())
  currentStatus       String?
  
  callingLogs         CallingLog[]
  mappingLogs         MappingLog[]
  deliveryLogs        DeliveryLog[]
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model CallingLog {
  id          String        @id @default(uuid())
  indentId    String
  indent      Indent        @relation(fields: [indentId], references: [id])
  status      String
  remarks     String?
  attemptDate DateTime      @default(now())
}

model MappingLog {
  id          String   @id @default(uuid())
  indentId    String
  indent      Indent   @relation(fields: [indentId], references: [id])
  mappedDate  DateTime @default(now())
  remarks     String?
}

model DeliveryLog {
  id          String         @id @default(uuid())
  indentId    String
  indent      Indent         @relation(fields: [indentId], references: [id])
  status      String
  updateDate  DateTime       @default(now())
  remarks     String?
}

model Transaction {
  id          String   @id @default(uuid())
  merchantId  String
  amount      Float
  date        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  timestamp DateTime @default(now())
}
